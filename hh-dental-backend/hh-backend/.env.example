# ── Server ───────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── CORS (add your real Vercel URLs after deploying) ──────
FRONTEND_URL=https://your-user-frontend.vercel.app
ADMIN_FRONTEND_URL=https://your-admin-panel.vercel.app
PUBLIC_FRONTEND_URL=https://your-user-frontend.vercel.app
CORS_ORIGINS=https://your-user-frontend.vercel.app,https://your-admin-panel.vercel.app

# ── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=HH_DENTAL_PROJECT

# ── Admin Seed ───────────────────────────────────────────
ADMIN_EMAIL=admin@hhdental.in
ADMIN_PASSWORD=YourStrongPassword@123

# ── Email ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=H&H Dental <noreply@hhdental.in>

# ── WhatsApp ─────────────────────────────────────────────
WHATSAPP_NUMBER=9999999999
